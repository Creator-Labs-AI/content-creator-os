{
  "name": "content-creator-os",
  "homepage": "https://content-creator-os.vercel.app",
  "author": "Content Creator OS",
  "version": "0.1.0",
  "private": true,
  "description": "Content Creator OS is a web application that provides a suite of tools and resources for content creators to manage, create, and distribute their content effectively.",
  "repository": {
    "type": "git",
    "url": "https://github.com/pradeepngupta/content-creator-os.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "tsc": "npx tsc --noEmit",
    "lint": "eslint --fix .",
    "format": "prettier --check . --config ./.prettierrc",
    "format:fix": "prettier --write . --config ./.prettierrc",
    "prepare": "husky",
    "pretest": "npm run lint && tsc --noEmit",
    "posttest": "npm run format",
    "test:jest": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test": "npm run test:jest --",
    "test:e2e": "npx playwright test",
    "test:e2e-ui": "npx playwright test --ui",
    "test:e2e-debug": "npx playwright test --debug"
  },
  "dependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "jest": "30.4.2",
    "next": "15.1.4",
    "playwright": "1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss-animate": "1.0.7",
    "typescript-eslint": "8.62.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.1.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
